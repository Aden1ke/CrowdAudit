# CrowdAudit Environment Template
# Copy this to .env and fill in your details

# --- API KEYS ---
# Get at: https://fred.stlouisfed.org/docs/api/api_key.html
# economic
FRED_API_KEY=your_fred_key_here

# Get at: https://trading.kalshi.com/ (Developer Settings)
KALSHI_API_KEY=your_kalshi_key_here
KALSHI_API_PASSPHRASE=your_passphrase_here
KALSHI_API_SECRET=your_secret_here

# Optional: If using a paid search scraper for high-volume Google Trends
SERPAPI_API_KEY=your_serpapi_key_here

#climate
NOAA_API_TOKEN=

#social
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crowdaudit/0.1 by your_username


NEWS_API_KEY=

# CONFIGURATION
APP_ENV=development
PORT=8000
DEBUG=True
LOOKBACK_HOURS=168
