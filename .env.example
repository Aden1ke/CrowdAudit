# CrowdAudit — Environment Variables
# Copy .env.example and fill in values.


#  Zerve 
# Your Zerve API key — found in Zerve dashboard under Settings > API Keys
ZERVE_API_KEY=your_zerve_api_key_here
 
# The URL of your deployed Zerve scoring endpoint
ZERVE_ENDPOINT_URL=

#  Economic data 
# FRED (Federal Reserve Economic Data)
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

#  Climate data 
# NOAA Climate Data Online
# Free token: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=

#  Social / narrative data 
# HackerNews — NO KEY NEEDED
# Uses Algolia public API: https://hn.algolia.com/api
# HACKERNEWS_API=no_key_needed

# Bluesky — NO KEY NEEDED
# Uses public AT Protocol API: https://public.api.bsky.app
# BLUESKY_API=no_key_needed

# Arctic Shift (Pushshift Reddit archive) — NO KEY NEEDED
# Community-maintained Reddit archive, no Reddit API access required
# https://arctic-shift.photon-reddit.com/api
# ARCTIC_SHIFT_API=no_key_needed

# Google Trends — NO KEY NEEDED
# Uses pytrends library (in requirements.txt), no signup required
# GOOGLE_TRENDS=no_key_needed

# Wikipedia — NO KEY NEEDED
# Public Wikimedia REST API: https://api.wikimedia.org/wiki/Core_REST_API
# WIKIPEDIA_API=no_key_needed

# NewsAPI — free tier (100 requests/day)
# Register: https://newsapi.org/register
NEWS_API_KEY=


#  Application 
APP_ENV=development
PORT=8000
DEBUG=True
LOOKBACK_HOURS=168
